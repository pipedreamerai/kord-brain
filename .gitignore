# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude worktrees (created by wt.sh)
.claude/worktrees/
.claude/settings.local.json
.worktree-port

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# vision pipeline derived artifacts + ad-hoc uploads
samples/derived/
samples/uploaded/
