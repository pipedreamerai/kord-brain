{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tag Bounding Boxes Sidecar",
  "description": "Hand-annotated tag locations for a PDF document.",
  "type": "object",
  "required": ["doc", "pages"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "doc": {
      "type": "string",
      "description": "Filename of the PDF this sidecar describes."
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["page", "tags"],
        "additionalProperties": false,
        "properties": {
          "page": { "type": "integer", "minimum": 1 },
          "tags": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["tag", "bbox"],
              "additionalProperties": false,
              "properties": {
                "tag": {
                  "type": "string",
                  "enum": ["P-101", "M-101", "CB-101", "MCC-1", "LSL-201", "CV-301", "T-101", "IR-2"]
                },
                "bbox": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 4,
                  "maxItems": 4,
                  "description": "[x0, y0, x1, y1] in PDF user-space coordinates (origin bottom-left)."
                },
                "kind": {
                  "type": "string",
                  "enum": ["symbol", "instrument", "label", "wire"]
                },
                "note": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
